VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# WhatsApp number for manual payment (international format, no leading +)
# Must match WHATSAPP_NUMBER in server/.env
# Example: 0801 234 5678 → 2348012345678
VITE_WHATSAPP_NUMBER=2348000000000

# ── Feature flags ────────────────────────────────────────────────────
# true  → full Paystack + cash/COD payment flow
# false → WhatsApp-only booking mode (temporary validation phase)
VITE_ENABLE_ONLINE_PAYMENT=false
