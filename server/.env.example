# ═══════════════════════════════════════════════════════════
# JMove Logistics — Environment Variables
# Copy this to server/.env and fill in the values
# ═══════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=production

# ── Database (MongoDB Atlas) ─────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/jmovelogistics?retryWrites=true&w=majority

# ── JWT Secrets (use these generated values or generate your own) ─
# Generate new ones: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=f8350b48e127ed1a0e2b09dd3098f1a2298ecd7292cda8e09927ca9a1b3cdc41
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=150c6d63d47f98be04aa11fc48305810e9aee146f71b6e666c57d7ff4118ffdc
JWT_REFRESH_EXPIRES_IN=30d

# ── Paystack ─────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developer
# Use LIVE keys (sk_live_...) for production, test keys for testing
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ── Frontend URL ──────────────────────────────────────────
# Your Vercel deployment URL (set after deploying frontend)
# Can be comma-separated for multiple: https://jmove.vercel.app,https://jmovelogistics.com
FRONTEND_URL=https://your-app.vercel.app

# ── Email (Optional — console logs if not set) ────────────
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=noreply@jmovelogistics.com

# ── Google Maps (Optional) ────────────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=
