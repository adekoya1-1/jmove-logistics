# JMove Logistics - Required Environment Variables
# Copy to .env and fill in all values. NEVER commit .env to git.

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/jmove

# JWT - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app-password
EMAIL_FROM=noreply@jmove.ng

# Frontend
FRONTEND_URL=http://localhost:5173

# Server
PORT=5000
NODE_ENV=development
